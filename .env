DATABASE_URL=file:/home/z/my-project/db/custom.db

# ===========================================================================
# ODSS Data Provider Credentials
# ===========================================================================
# These are YOUR credentials. Add them here and save the file.
# The engine reads them at runtime. They are NEVER logged or shared.
#
# At minimum, the NSE provider works with NO credentials (free, public).
# To get real-time data with higher limits, add Angel One credentials.
# ===========================================================================

# --- Angel One SmartAPI (https://smartapi.angelbroking.com) ---
# Get these from the SmartAPI dashboard after creating an app.
ANGEL_API_KEY=89VbK66s
ANGEL_API_SECRET=
ANGEL_CLIENT_CODE=
ANGEL_PIN=
# Feed token is auto-generated on login — leave blank

# --- Server IP (for Angel One API headers) ---
SERVER_PUBLIC_IP=47.57.242.119

# --- Upstox API v2 (https://upstox.com/developer/api) ---
# Add later when you have Upstox credentials
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=
UPSTOX_REDIRECT_URI=

# --- Data Source Selection ---
# Which provider to prefer: ANGEL_ONE | UPSTOX | NSE | AUTO
# AUTO = use the best available provider, fall back gracefully
DATA_PROVIDER=AUTO

# --- NSE Proxy (Optional but recommended) ---
# Deploy a free proxy in Mumbai region (Vercel/Cloudflare) to bypass NSE geo-block.
# See: /home/z/my-project/nse-proxy/README.md for deployment guide.
NSE_PROXY_URL=
NSE_PROXY_SECRET=
